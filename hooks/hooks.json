{
  "description": "Auto-update claude-skills from GitHub on session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PLUGIN_ROOT}\" && git pull --quiet --ff-only 2>/dev/null || true",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
